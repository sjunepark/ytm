{
  "name": "@sjunepark/ytm",
  "version": "0.1.1",
  "description": "Deterministic CLI and neutral toolset for KIS-NET YTM Matrix lookups.",
  "type": "module",
  "packageManager": "bun@1.3.13",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sjunepark/ytm.git",
    "directory": "packages/node"
  },
  "bin": {
    "ytm": "dist/cli.js"
  },
  "exports": {
    "./toolset": {
      "types": "./dist/toolset.d.ts",
      "import": "./dist/toolset.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "skills",
    "README.md",
    "SPEC.md",
    "LICENSE.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20.18.1"
  },
  "license": "MIT",
  "scripts": {
    "build": "bun scripts/build.mjs",
    "prepack": "bun run build",
    "prepublishOnly": "bun run build && bun run validate",
    "cli": "bun run src/cli.js",
    "validate": "bun scripts/validate-tool-surface.mjs",
    "test": "bun run build && bun run validate",
    "smoke": "node dist/cli.js matrix --base-date 2026-06-08 --kind 국채 --format json"
  }
}
