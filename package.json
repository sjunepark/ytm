{
  "name": "kisnet-ytm",
  "version": "0.1.0",
  "description": "Deterministic CLI and neutral toolset for KIS-NET YTM Matrix lookups.",
  "type": "module",
  "bin": {
    "kisnet-ytm": "./dist/cli.js"
  },
  "exports": {
    "./toolset": {
      "types": "./dist/toolset.d.ts",
      "import": "./dist/toolset.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "SPEC.md"
  ],
  "scripts": {
    "build": "node scripts/build.mjs",
    "validate": "node scripts/validate-tool-surface.mjs",
    "smoke": "node dist/cli.js lookup-ytm-matrix --base-date 2026-06-08 --kind 국채 --format json"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT"
}
