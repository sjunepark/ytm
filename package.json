{
  "name": "kisnet-ytm",
  "version": "0.1.0",
  "description": "Deterministic CLI and neutral toolset for KIS-NET YTM Matrix lookups.",
  "type": "module",
  "packageManager": "bun@1.3.13",
  "bin": {
    "ytm": "./dist/cli.js"
  },
  "exports": {
    "./toolset": {
      "types": "./dist/toolset.d.ts",
      "import": "./dist/toolset.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "SPEC.md"
  ],
  "scripts": {
    "build": "bun scripts/build.mjs",
    "validate": "bun scripts/validate-tool-surface.mjs",
    "cli": "bun run src/cli.js",
    "smoke": "bun dist/cli.js matrix --base-date 2026-06-08 --kind 국채 --format json"
  },
  "engines": {
    "bun": ">=1.3.13"
  },
  "license": "MIT"
}
